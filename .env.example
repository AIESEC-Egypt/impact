# Copy to .env and fill in real values. NEVER commit the real .env.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=impact.aiesec.org.eg
DJANGO_CSRF_TRUSTED_ORIGINS=https://impact.aiesec.org.eg

# EXPA OAuth (server-side). Secret stays in .env or Django admin only.
EXPA_CLIENT_ID=
EXPA_CLIENT_SECRET=
EXPA_AUTH_URL=https://auth.aiesec.org/oauth/authorize
EXPA_TOKEN_URL=https://auth.aiesec.org/oauth/token
EXPA_PEOPLE_ME_URL=https://gis-api.aiesec.org/v2/current_person
EXPA_REDIRECT_URI=https://impact.aiesec.org.eg/
EXPA_ALLOWED_ENTITIES=egypt
EXPA_REQUIRE_ACTIVE_MEMBER=True

# Member roster (EDM): sync from EXPA; login only if expa_id is in roster
EXPA_USE_MEMBER_ROSTER=True
EXPA_SYNC_ACCESS_TOKEN=
EXPA_SYNC_OFFICE_ID=
EXPA_SYNC_DATE_FROM=2025-01-01
EXPA_SYNC_DATE_TO=

# Optional Postgres (leave POSTGRES_DB empty to use SQLite)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=
POSTGRES_CONN_MAX_AGE=60
