# Copy these into Coolify → Environment Variables (do not commit real values to git).

# --- Django ---
DJANGO_SECRET_KEY=replace-with-output-of-get_random_secret_key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=impact.aiesec.org.eg
DJANGO_CSRF_TRUSTED_ORIGINS=https://impact.aiesec.org.eg
DJANGO_SECURE_SSL_REDIRECT=True

# --- DigitalOcean PostgreSQL (Coolify / managed DB) ---
POSTGRES_DB=defaultdb
POSTGRES_USER=doadmin
POSTGRES_PASSWORD=your-db-password
POSTGRES_HOST=your-host.db.ondigitalocean.com
POSTGRES_PORT=25060
POSTGRES_SSLMODE=require
POSTGRES_CONN_MAX_AGE=60

# --- EXPA OAuth ---
EXPA_CLIENT_ID=
EXPA_CLIENT_SECRET=
EXPA_AUTH_URL=https://auth.aiesec.org/oauth/authorize
EXPA_TOKEN_URL=https://auth.aiesec.org/oauth/token
EXPA_PEOPLE_ME_URL=https://gis-api.aiesec.org/v2/current_person
EXPA_REDIRECT_URI=https://impact.aiesec.org.eg/
EXPA_ALLOWED_ENTITIES=egypt
EXPA_REQUIRE_ACTIVE_MEMBER=True

# --- Member roster sync (optional; also configurable in admin) ---
EXPA_USE_MEMBER_ROSTER=True
EXPA_SYNC_ACCESS_TOKEN=
EXPA_SYNC_OFFICE_ID=
EXPA_SYNC_DATE_FROM=2025-01-01
EXPA_SYNC_DATE_TO=

# --- Gunicorn (optional) ---
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
